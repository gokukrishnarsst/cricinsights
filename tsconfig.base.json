{
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@cricket-ai/database": ["libs/database/src/index.ts"],
      "@cricket-ai/mcp-server": ["libs/mcp-server/src/index.ts"],
      "@cricket-ai/insight-engine": ["libs/insight-engine/src/index.ts"],
      "@cricket-ai/ai-agent": ["libs/ai-agent/src/index.ts"],
      "@cricket-ai/smart-router": ["libs/smart-router/src/index.ts"]
    },
    "composite": true,
    "declarationMap": true,
    "emitDeclarationOnly": true,
    "importHelpers": true,
    "isolatedModules": true,
    "lib": ["es2022"],
    "module": "nodenext",
    "moduleResolution": "nodenext",
    "noEmitOnError": true,
    "noFallthroughCasesInSwitch": true,
    "noImplicitOverride": true,
    "noImplicitReturns": true,
    "noUnusedLocals": true,
    "skipLibCheck": true,
    "strict": true,
    "target": "es2022",
    "customConditions": ["@cricket-ai/source"]
  }
}
