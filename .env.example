# Copy to .env for local development: cp .env.example .env

# App / CDK environment name (matches stack suffix: CricketStack-dev)
ENV=dev

# Local Postgres (docker compose). Change DATABASE_PORT if 5433 is already in use.
DATABASE_HOST=localhost
DATABASE_PORT=5433
DATABASE_NAME=cricket_ai_dev
DATABASE_USER=cricketadmin
DATABASE_PASSWORD=cricketadmin
DATABASE_URL=postgresql://cricketadmin:cricketadmin@localhost:5433/cricket_ai_dev

# AWS CDK deploy (set when deploying to AWS)
# REGION=ap-southeast-2
# CDK_DEFAULT_ACCOUNT=123456789012
# AWS_PROFILE=your-profile

# CricInsights web app
OPENAI_API_KEY=
# Set in production (Vercel) to the WaitlistApiUrl CDK output
# NEXT_PUBLIC_WAITLIST_API_URL=https://...
