# Copy to .env for local development: cp .env.example .env

# App / CDK environment name (matches stack suffix: CricketStack-dev)
ENV=dev

# Remote Aurora (read-only) — used by MCP tools, Fast Path API, and AI agent queries
REMOTE_DATABASE_URL=postgresql://read_only_user:password@your-aurora-host:5432/cricket_ai_dev?sslmode=require
# Optional override for Aurora TLS (default: libs/database/certs/rds-global-bundle.pem)
# DATABASE_SSL_CA_PATH=

# Local Postgres (docker compose). Used for Flyway migrations and waitlist writes.
DATABASE_HOST=localhost
DATABASE_PORT=5433
DATABASE_NAME=cricket_ai_dev
DATABASE_USER=cricketadmin
DATABASE_PASSWORD=cricketadmin
DATABASE_URL=postgresql://cricketadmin:cricketadmin@localhost:5433/cricket_ai_dev

# AWS CDK deploy (set when deploying to AWS)
# REGION=ap-southeast-2
# CDK_DEFAULT_ACCOUNT=123456789012
# AWS_PROFILE=your-profile

# CricInsights web app
OPENAI_API_KEY=

# Bedrock agent tool-use loop (default 12). Raise for complex multi-tool questions.
AGENT_MAX_TOOL_ITERATIONS=12

# Set in production (Vercel) to the WaitlistApiUrl CDK output
# NEXT_PUBLIC_WAITLIST_API_URL=https://...
