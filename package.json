{
  "name": "@cricket-ai/source",
  "version": "0.0.0",
  "license": "MIT",
  "packageManager": "pnpm@10.11.1",
  "private": true,
  "scripts": {
    "build": "nx run-many --target=build",
    "typecheck": "nx run-many --target=typecheck",
    "synth": "nx run-many --target=synth",
    "diff": "nx run-many --target=diff",
    "deploy": "nx run-many --target=deploy",
    "db:up": "docker compose up -d postgres",
    "db:down": "docker compose down",
    "db:reset": "docker compose down -v && docker compose up -d postgres",
    "db:migrate": "docker compose up -d postgres && nx run database:migrate-local",
    "db:logs": "docker compose logs -f postgres",
    "db:ps": "docker compose ps",
    "dev:web": "nx dev cricinsights"
  },
  "dependencies": {
    "aws-cdk-lib": "^2.260.0",
    "constructs": "^10.6.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.8.0",
    "@next/eslint-plugin-next": "^16.1.6",
    "@nx/eslint": "^23.0.0",
    "@nx/eslint-plugin": "23.0.0",
    "@nx/js": "23.0.0",
    "@nx/next": "23.0.0",
    "@nx/react": "23.0.0",
    "@nx/workspace": "23.0.0",
    "@swc-node/register": "~1.11.1",
    "@swc/cli": "~0.8.0",
    "@swc/core": "~1.15.5",
    "@swc/helpers": "~0.5.18",
    "@types/aws-lambda": "^8.10.162",
    "@types/node": "^22.0.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "autoprefixer": "^10.5.2",
    "aws-cdk": "^2.1128.1",
    "eslint": "^9.8.0",
    "eslint-config-next": "^16.2.9",
    "eslint-config-prettier": "^10.0.0",
    "eslint-plugin-import": "2.31.0",
    "eslint-plugin-jsx-a11y": "6.10.1",
    "eslint-plugin-react": "7.35.0",
    "eslint-plugin-react-hooks": "5.0.0",
    "next": "^16.2.9",
    "nx": "23.0.0",
    "postcss": "^8.5.16",
    "prettier": "^3.8.1",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "tailwindcss": "^4.3.2",
    "tslib": "^2.3.0",
    "tsx": "^4.22.4",
    "typescript": "~5.9.2",
    "typescript-eslint": "^8.40.0"
  }
}
